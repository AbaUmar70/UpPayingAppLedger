  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^11.0.0",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  }
}
